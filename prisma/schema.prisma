// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js Base Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Custom App Models
enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?   // For credential login
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Dynamic Platform Models
model Module {
  id          String   @id @default(cuid())
  name        String   // e.g. "Header Principal"
  type        String   // e.g. "header", "hero", "cards", "footer", "contact"
  config      Json     // JSON string storing specific settings (colors, text, images content) 
  isActive    Boolean  @default(true)
  order       Int      @default(0) // Render order on the front page
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Global Brand and Environment settings
model Settings {
  id               String   @id @default("global")
  siteTitle        String   @default("Mi Negocio")
  siteDescription String   @default("Descripción de mi negocio")
  faviconUrl       String?
  ogImageUrl       String?
  logoUrl          String?
  primaryColor     String   @default("#7c3aed")
  secondaryColor   String   @default("#06b6d4")
  backgroundColor  String   @default("#000000")
  businessName     String?
  contactEmail     String?
  contactPhone     String?      // Mantener por retrocompatibilidad
  contactPhones    Json?        // Nuevo: Array de teléfonos ["+34...", "+34..."]
  address          String?
  city             String?
  province         String?
  country          String?
  locationMapUrl   String?      // URL de Google Maps o similar
  
  updatedAt        DateTime @updatedAt
}
